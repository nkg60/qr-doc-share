# Copiez ce fichier en ".env" pour le développement local (netlify dev le lit
# automatiquement). En production, définissez ces variables dans l'interface
# Netlify : Site configuration > Environment variables.

# --- V1.1 : multi-utilisateurs ------------------------------------------------
# ACCESS_CODES : un JSON décrivant tous les utilisateurs, sur UNE seule ligne.
#   - clé        = code d'accès à 6 chiffres
#   - label      = nom lisible (affiché dans l'interface et les exports)
#   - max_bytes  = quota individuel en octets (104857600 = 100 Mo)
#   - is_admin   = optionnel ; true donne la vue globale (tous les documents,
#                  tous les scans, filtre par propriétaire, documents legacy)
# Ce JSON n'est JAMAIS envoyé au frontend : vérification côté serveur uniquement.
ACCESS_CODES={"123456": {"label": "Ghislain", "max_bytes": 104857600, "is_admin": true}, "789012": {"label": "Marc", "max_bytes": 52428800}, "345678": {"label": "Roxane", "max_bytes": 209715200}}

# --- Anciennes variables V1 (migration douce) ----------------------------------
# Si ACCESS_CODES est absent mais qu'ACCESS_CODE existe, le serveur reconstruit
# automatiquement un utilisateur unique "legacy" (admin) avec le quota
# MAX_TOTAL_BYTES. Gardez-les seulement le temps de la transition, puis
# supprimez-les une fois ACCESS_CODES en place.
# ACCESS_CODE=123456
# MAX_TOTAL_BYTES=104857600
