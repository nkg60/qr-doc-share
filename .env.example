# Copiez ce fichier en ".env" pour le développement local (netlify dev le lit
# automatiquement). En production, définissez ces variables dans l'interface
# Netlify : Site configuration > Environment variables.

# Code d'accès à 6 chiffres exigé pour importer un document.
# Il n'apparaît JAMAIS dans le frontend : il est vérifié uniquement côté serveur.
ACCESS_CODE=123456

# Quota global de stockage en octets, tous documents confondus.
# Un upload qui ferait dépasser ce total est refusé.
# Exemple : 104857600 = 100 Mo.
MAX_TOTAL_BYTES=104857600
